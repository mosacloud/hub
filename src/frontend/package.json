{
  "name": "hub",
  "version": "0.0.1",
  "private": true,
  "repository": "https://github.com/suitenumerique/docs",
  "author": "DINUM",
  "license": "MIT",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "servers/*"
    ]
  },
  "scripts": {
    "APP_HUB": "yarn workspace app-hub",
    "APP_E2E": "yarn workspace app-e2e",
    "I18N": "yarn workspace packages-i18n",
    "app:dev": "yarn APP_HUB run dev",
    "app:start": "yarn APP_HUB run start",
    "app:build": "yarn APP_HUB run build",
    "app:test": "yarn APP_HUB run test",
    "ci:build": "yarn APP_HUB run build:ci",
    "e2e:test": "yarn APP_E2E run test",
    "lint": "yarn APP_HUB run lint && yarn APP_E2E run lint && yarn I18N run lint",
    "lint-fix": "yarn APP_HUB run lint --fix && yarn APP_E2E run lint --fix && yarn I18N run lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "i18n:extract": "yarn I18N run extract-translation",
    "i18n:deploy": "yarn I18N run format-deploy",
    "i18n:test": "yarn I18N run test",
    "test": "yarn app:test"
  },
  "devDependencies": {
    "prettier": "3.8.3"
  },
  "resolutions": {
    "@next/eslint-plugin-next": "15.1.7",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.20.1",
    "eslint-config-next": "15.1.7",
    "glob": "13.0.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "serialize-javascript": "7.0.5",
    "typescript": "5.9.3",
    "wrap-ansi": "10.0.0"
  },
  "packageManager": "yarn@1.22.22"
}
